api_key = 'o9NfoSRmyQfE5ipiaKS7jku9n5C6G1dV'

def fetch_fmp_comp_info(symbol_list, api_key=''):
    url = 'https://financialmodelingprep.com/stable/profile'
    dfs = []
    
    for symbol in symbol_list:
        params = {
            'symbol': symbol,
            'apikey': api_key
        }
        response = requests.get(url, params=params)
        data = response.json()
        
        if not data:
            print(f"No data for {symbol}")
            continue
            
        df = pd.DataFrame(data)
        df_clean = df[[
            "cik",
            "symbol",
            "companyName",
            "sector",
            "industry",
            "exchange",
            "country",
            "currency",
            "marketCap",
            "ipoDate",
            "isActivelyTrading",
            "isEtf",
            "isAdr",
            "isFund"
        ]].rename(columns={
            "symbol":            "ticker",
            "companyName":       "name",
            "marketCap":         "market_cap",
            "ipoDate":           "ipo_date",
            "isActivelyTrading": "is_active",
            "isEtf":             "is_etf",
            "isAdr":             "is_adr",
            "isFund":            "is_fund"
        })
        dfs.append(df_clean)
    
    return pd.concat(dfs, ignore_index=True)


df = pd.read_csv('companies2.csv')
df = df.drop(columns=["Unnamed: 0"])
df_clean = df.drop_duplicates(subset=["cik"], keep="first")



# Clear table first
with engine.begin() as conn:
    conn.execute(text("TRUNCATE TABLE companies"))

# Then insert
df_clean.to_sql("companies", con=engine, if_exists="append", index=False)
print(f"Inserted {len(df_clean)} rows!")



