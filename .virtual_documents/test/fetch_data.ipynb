    df_clean["period_type"] = df_clean["period_type"].map(
        lambda x: "annual" if x == "FY" else "quarterly"
    )
    df_clean = df_clean.dropna(subset=["cik"])
    df_clean["cik"] = df_clean["cik"].astype(int)
    
    return df_clean



