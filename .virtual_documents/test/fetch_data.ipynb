        response = requests.get(url, params=params)
        data = response.json()
        
        if not data:
            print(f"No data for {symbol}")
            continue
        
        dfs.append(pd.DataFrame(data))
        time.sleep(time_sleep)
        
        if (i + 1) % 100 == 0:
            print(f"Progress: {i + 1} / {len(symbol_lst)} fetched...")
    
    if not dfs:
        return pd.DataFrame()
    
    df = pd.concat(dfs, ignore_index=True)
    
