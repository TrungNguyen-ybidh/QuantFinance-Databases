        "symbol":                               "ticker",
        "date":                                 "period_date",
        "period":                               "period_type",
        "fiscalYear":                           "fiscal_year",
        "operatingCashFlow":                    "operating_cash_flow",
        "netCashProvidedByInvestingActivities": "investing_cash_flow",
        "netCashProvidedByFinancingActivities": "financing_cash_flow",
