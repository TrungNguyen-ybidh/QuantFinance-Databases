def fetch_income(symbol_lst):
    dfs = []
    for comp in symbol_lst:
        company = Company(comp)
        filings_10q = company.get_filings(form="10-Q")
        xbrls = XBRLS.from_filings(filings_10q)
        df = xbrls.statements.income_statement().to_dataframe()
        df = df.drop(columns=['concept', 'standard_concept', 'preferred_sign'])
        df = df.set_index('label')

        # Filter out YTD columns BEFORE transposing
        df = df[[col for col in df.columns if 'YTD' not in col]]

        df = df.T.reset_index()
        df.rename(columns={'index': 'Date'}, inplace=True)
        df = df.drop(columns='Acquisition termination cost')
        df['ticker'] = comp
        dfs.append(df)
    dataframe = pd.concat(dfs, ignore_index=True)
    dataframe.insert(1, 'ticker', dataframe.pop('ticker'))
    return dataframe


companylist = [ 'NVDA'
]
df4 = fetch_income(companylist)
df4


df4.to_csv("income_statement_edgar4.csv")


